---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = 'DevApplications | Estudio Indie de Videojuegos Móviles · Barcelona',
  description = 'DevApplications es un estudio indie de videojuegos móviles creado por Antonio Ramos en Barcelona. Creamos juegos arcade rejugables para Android, sin muros de pago ni sistemas de energía. Descubre Infinite Dark, nuestro Space Survivor Roguelite.',
  ogImage = '/images/logoDevApplications.png',
  canonicalUrl = Astro.url.pathname,
} = Astro.props;

const siteUrl = 'https://devapplications.xyz';
const fullCanonical = `${siteUrl}${canonicalUrl}`;
const fullOgImage = `${siteUrl}${ogImage}`;

const jsonLdOrganization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'DevApplications',
  url: siteUrl,
  logo: `${siteUrl}/images/logoDevApplications.png`,
  description: 'Estudio indie de videojuegos móviles arcade, creado por Antonio Ramos en Barcelona.',
  foundingLocation: {
    '@type': 'Place',
    name: 'Barcelona, España',
  },
  founder: {
    '@type': 'Person',
    name: 'Antonio Ramos',
    jobTitle: 'Indie Game Developer',
  },
  sameAs: [
    'https://play.google.com/store/apps/developer?id=DevApplications',
    'mailto:devapplicationsgames@gmail.com',
  ],
};

const jsonLdGame = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Infinite Dark',
  description: 'Space Survivor Roguelite para Android. Sobrevive a oleadas de enemigos, descubre sinergias entre armas y mejora tus estadísticas run a run.',
  image: `${siteUrl}/images/principal-logo-infinite-dark.png`,
  operatingSystem: 'Android',
  applicationCategory: 'GameApplication',
  genre: ['Roguelite', 'Arcade', 'Shooter', 'Survival'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    url: 'https://play.google.com/store/apps/details?id=com.devapplications.infiniteDark',
  },
  publisher: {
    '@type': 'Organization',
    name: 'DevApplications',
  },
  author: {
    '@type': 'Person',
    name: 'Antonio Ramos',
  },
};

const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DevApplications',
  url: siteUrl,
  description,
  inLanguage: ['es', 'en'],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Favicon ── -->
    <link rel="icon" type="image/png" href="/images/logoDevApplications.png" />
    <link rel="apple-touch-icon" href="/images/logoDevApplications.png" />

    <!-- ── Primary meta ── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Antonio Ramos – DevApplications" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="keywords" content="DevApplications, indie game studio, videojuegos móviles, juegos Android, Infinite Dark, Space Survivor Roguelite, arcade game, roguelite, Barcelona, estudio videojuegos, mobile games" />
    <meta name="theme-color" content="#020514" />
    <meta name="generator" content={Astro.generator} />

    <!-- ── Canonical & hreflang ── -->
    <link rel="canonical" href={fullCanonical} />
    <link rel="alternate" hreflang="es" href={fullCanonical} />
    <link rel="alternate" hreflang="en" href={fullCanonical} />
    <link rel="alternate" hreflang="x-default" href={fullCanonical} />

    <!-- ── Open Graph ── -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DevApplications" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DevApplications – Indie Game Studio" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- ── Twitter / X Card ── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content="DevApplications – Indie Game Studio" />

    <!-- ── Structured Data (JSON-LD) ── -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdGame)} />

    <!-- ── Fonts ── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        color-scheme: dark;
        --bg: #020514;
        --bg-card: rgba(6, 14, 48, 0.5);
        --accent-cyan: #39ffe3;
        --accent-purple: #b043ff;
        --accent-blue: #4bb3ff;
        --text-main: #e6f3ff;
        --text-soft: #7a98c4;
        --text-muted: #4a6490;
        --border: rgba(75, 140, 220, 0.15);
        --border-active: rgba(75, 179, 255, 0.35);
        --gradient-cta: linear-gradient(135deg, var(--accent-cyan), var(--accent-blue));
        --shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
        --shadow-lg: 0 24px 64px rgba(0, 0, 0, 0.8);
        --radius: 16px;
        --radius-lg: 24px;
        --nav-height: 64px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text-main);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        line-height: 1.6;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse 70% 60% at 10% -5%, rgba(57, 255, 227, 0.07), transparent),
          radial-gradient(ellipse 60% 70% at 90% 100%, rgba(176, 67, 255, 0.09), transparent),
          radial-gradient(ellipse 40% 50% at 50% 50%, rgba(75, 179, 255, 0.03), transparent);
        pointer-events: none;
        z-index: 0;
      }

      body > * {
        position: relative;
        z-index: 1;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-weight: 700;
        line-height: 1.1;
      }

      /* ======== NAV ======== */
      .site-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        height: var(--nav-height);
        display: flex;
        align-items: center;
        padding: 0 2rem;
        border-bottom: 1px solid transparent;
        transition: background 0.3s, border-color 0.3s;
      }

      .site-nav.is-scrolled {
        background: rgba(2, 5, 20, 0.88);
        backdrop-filter: blur(20px) saturate(150%);
        border-bottom-color: var(--border);
      }

      .nav-inner {
        max-width: 1160px;
        width: 100%;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }

      .nav-brand {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-shrink: 0;
      }

      .nav-logo {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        overflow: hidden;
        border: 1px solid rgba(57, 255, 227, 0.25);
        background: rgba(4, 10, 36, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .nav-logo img {
        width: 130%;
        height: auto;
        filter: drop-shadow(0 0 5px rgba(57, 255, 227, 0.5));
      }

      .nav-name {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text-main);
      }

      .nav-links {
        display: none;
        align-items: center;
        gap: 0.125rem;
      }

      @media (min-width: 768px) {
        .nav-links {
          display: flex;
        }
      }

      .nav-link {
        padding: 0.375rem 0.875rem;
        border-radius: 999px;
        font-size: 0.845rem;
        font-weight: 500;
        color: var(--text-soft);
        transition: color 0.2s, background 0.2s;
      }

      .nav-link:hover {
        color: var(--text-main);
        background: rgba(75, 140, 220, 0.08);
      }

      .nav-link[data-active='true'] {
        color: var(--accent-cyan);
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
      }

      .lang-toggle {
        display: flex;
        align-items: center;
        gap: 0.125rem;
        background: rgba(4, 10, 36, 0.8);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.2rem;
      }

      .lang-btn {
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        cursor: pointer;
        border: none;
        background: transparent;
        color: var(--text-soft);
        transition: all 0.2s;
        font-family: inherit;
      }

      .lang-btn[data-active='true'] {
        background: var(--accent-cyan);
        color: #020514;
      }

      /* ======== SHARED BUTTONS ======== */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.65rem 1.4rem;
        border-radius: 999px;
        font-size: 0.875rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        border: none;
        white-space: nowrap;
      }

      .btn-primary {
        background: var(--gradient-cta);
        color: #020514;
        box-shadow: 0 4px 20px rgba(57, 255, 227, 0.2);
      }

      .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 8px 28px rgba(57, 255, 227, 0.3);
      }

      .btn-secondary {
        background: transparent;
        color: var(--text-main);
        border: 1px solid var(--border-active);
      }

      .btn-secondary:hover {
        background: rgba(75, 140, 220, 0.08);
        transform: translateY(-1px);
      }

      .btn-ghost {
        background: rgba(6, 14, 48, 0.8);
        color: var(--text-soft);
        border: 1px solid var(--border);
      }

      .btn-ghost:hover {
        border-color: var(--border-active);
        color: var(--text-main);
        transform: translateY(-1px);
      }

      /* ======== LAYOUT ======== */
      .container {
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      /* ======== CARD ======== */
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        backdrop-filter: blur(12px);
        transition: border-color 0.25s, box-shadow 0.25s;
      }

      .card:hover {
        border-color: var(--border-active);
        box-shadow: var(--shadow);
      }

      /* ======== LABEL ======== */
      .label {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-cyan);
      }

      .label-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent-cyan);
        box-shadow: 0 0 6px var(--accent-cyan);
        flex-shrink: 0;
      }

      .section-title {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        letter-spacing: -0.025em;
        color: var(--text-main);
      }

      /* ======== FOOTER ======== */
      .site-footer {
        margin-top: 6rem;
        padding: 2rem;
        border-top: 1px solid var(--border);
      }

      .footer-inner {
        max-width: 1160px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.8rem;
        color: var(--text-muted);
      }

      .footer-links {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .footer-a {
        color: var(--text-soft);
        transition: color 0.2s;
      }

      .footer-a:hover {
        color: var(--accent-cyan);
      }

      /* ======== I18N ======== */
      [data-i18n] {
        display: inline;
      }
    </style>
  </head>
  <body data-lang="es">

    <nav class="site-nav" id="site-nav">
      <div class="nav-inner">
        <a href="#home" class="nav-brand">
          <div class="nav-logo">
            <img src="/images/logoDevApplications.png" alt="DevApplications" loading="lazy" />
          </div>
          <span class="nav-name">DevApplications</span>
        </a>

        <div class="nav-links">
          <a href="#home" class="nav-link" data-nav-link data-section="home" data-active="true">
            <span data-i18n="es">Inicio</span>
            <span data-i18n="en">Home</span>
          </a>
          <a href="#games" class="nav-link" data-nav-link data-section="games">
            <span data-i18n="es">Juegos</span>
            <span data-i18n="en">Games</span>
          </a>
          <a href="#studio" class="nav-link" data-nav-link data-section="studio">
            <span data-i18n="es">Estudio</span>
            <span data-i18n="en">Studio</span>
          </a>
          <a href="#contact" class="nav-link" data-nav-link data-section="contact">
            <span data-i18n="es">Contacto</span>
            <span data-i18n="en">Contact</span>
          </a>
        </div>

        <div class="nav-actions">
          <div class="lang-toggle" aria-label="Language selector">
            <button type="button" class="lang-btn" data-lang-switch="es" data-active="true">ES</button>
            <button type="button" class="lang-btn" data-lang-switch="en">EN</button>
          </div>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <span>
          <span data-i18n="es">Hecho en Barcelona &middot; &copy; {new Date().getFullYear()} DevApplications</span>
          <span data-i18n="en">Made in Barcelona &middot; &copy; {new Date().getFullYear()} DevApplications</span>
        </span>
        <div class="footer-links">
          <a href="mailto:devapplicationsgames@gmail.com" class="footer-a">devapplicationsgames@gmail.com</a>
          <a
            href="https://play.google.com/store/apps/developer?id=DevApplications"
            target="_blank"
            rel="noreferrer"
            class="footer-a"
          >Google Play</a>
        </div>
      </div>
    </footer>

    <script>
      (function () {
        const body = document.body;
        const nav = document.getElementById('site-nav');
        const langBtns = document.querySelectorAll('[data-lang-switch]');
        const navLinks = document.querySelectorAll('[data-nav-link]');

        // Language
        const stored = localStorage.getItem('devapps-lang');
        applyLang(stored === 'en' || stored === 'es' ? stored : 'es');

        langBtns.forEach((btn) => {
          btn.addEventListener('click', () => {
            applyLang(btn.getAttribute('data-lang-switch'));
          });
        });

        function applyLang(lang) {
          body.dataset.lang = lang;
          localStorage.setItem('devapps-lang', lang);
          document.querySelectorAll('[data-i18n="es"]').forEach((el) => {
            (el as HTMLElement).style.display = lang === 'es' ? '' : 'none';
          });
          document.querySelectorAll('[data-i18n="en"]').forEach((el) => {
            (el as HTMLElement).style.display = lang === 'en' ? '' : 'none';
          });
          langBtns.forEach((btn) => {
            (btn as HTMLElement).dataset.active =
              btn.getAttribute('data-lang-switch') === lang ? 'true' : 'false';
          });
        }

        // Nav scroll state
        if (nav) {
          window.addEventListener(
            'scroll',
            () => {
              nav.classList.toggle('is-scrolled', window.scrollY > 10);
            },
            { passive: true }
          );
        }

        // Active section
        const sections = ['home', 'games', 'studio', 'contact']
          .map((id) => document.getElementById(id))
          .filter(Boolean);

        if ('IntersectionObserver' in window && sections.length) {
          const obs = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                navLinks.forEach((l) => {
                  (l as HTMLElement).dataset.active =
                    l.getAttribute('data-section') === entry.target.id ? 'true' : 'false';
                });
              });
            },
            { threshold: 0.3 }
          );
          sections.forEach((el) => obs.observe(el!));
        }
      })();
    </script>
  </body>
</html>
