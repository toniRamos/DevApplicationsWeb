---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="DevApplications — Arcade Indie Studio · Barcelona"
  description="DevApplications es un estudio indie de videojuegos móviles creado por Antonio Ramos en Barcelona. Juegos arcade rejugables para Android, sin muros de pago ni sistemas de energía."
>

  <!-- ── HERO ── -->
  <header id="home" class="hero">
    <div class="container">
      <div class="hero-meta reveal">
        <span class="eyebrow">
          <span data-i18n="es">Estudio Indie · Barcelona</span>
          <span data-i18n="en">Indie Studio · Barcelona</span>
        </span>
        <span class="eyebrow-num">EST. 2014 · NO. 02 · 2026</span>
      </div>

      <div class="hero-grid">
        <div>
          <h1 class="hero-title">
            <span class="line" data-i18n="es">Arcade games</span>
            <span class="line" data-i18n="en">Arcade games</span>
            <span class="line" data-i18n="es">que <span class="ital">no puedes</span></span>
            <span class="line" data-i18n="en">you <span class="ital">can't put</span></span>
            <span class="line" data-i18n="es"><span class="u">soltar.</span></span>
            <span class="line" data-i18n="en"><span class="u">down.</span></span>
          </h1>

          <p class="hero-sub" data-i18n="es">
            Creamos <strong>juegos móviles</strong> rápidos, rejugables y sin trampas. Cada partida es diferente,
            cada run tiene su propia historia. <strong>Sin muros de pago.</strong> <strong>Sin sistemas de energía.</strong>
          </p>
          <p class="hero-sub" data-i18n="en">
            We build <strong>fast, replayable mobile games</strong> with no tricks. Every run is different,
            every run tells its own story. <strong>No paywalls.</strong> <strong>No energy systems.</strong>
          </p>

          <div class="hero-actions">
            <a href="#games" class="btn">
              <span data-i18n="es">Ver juegos</span><span data-i18n="en">Our games</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
            <a href="#studio" class="btn ghost">
              <span data-i18n="es">Sobre el estudio</span><span data-i18n="en">About the studio</span>
            </a>
          </div>

          <div class="scroll-cue">
            <span data-i18n="es">Desplaza para explorar</span>
            <span data-i18n="en">Scroll to explore</span>
            <span class="scroll-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
            </span>
          </div>
        </div>

        <aside class="hero-card reveal" style="--d:120ms">
          <div class="hero-card-head">
            <span>FEATURED · No. 01</span>
            <span>∘ LIVE</span>
          </div>
          <div class="hero-card-body">
            <img src="/images/logoDevApplications.png" alt="DevApplications logo" loading="eager" />
          </div>
          <dl class="hero-card-foot">
            <div>
              <dt>Founded</dt>
              <dd>2014</dd>
            </div>
            <div>
              <dt>Games</dt>
              <dd>02</dd>
            </div>
            <div>
              <dt>Place</dt>
              <dd>BCN</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </header>

  <!-- ── GAMES ── -->
  <section id="games" class="band">
    <div class="container">
      <div class="band-head reveal">
        <div class="band-meta">
          <span>§ <strong>02</strong> / Catálogo</span>
          <span data-i18n="es">Dos títulos · Android</span>
          <span data-i18n="en">Two titles · Android</span>
        </div>
        <h2 class="band-title">
          <span data-i18n="es">Nuestros <em>juegos</em>, uno por uno.</span>
          <span data-i18n="en">Our <em>games</em>, one by one.</span>
        </h2>
      </div>

      <div class="games">

        <!-- Arkanoid Classic -->
        <article class="game reveal">
          <div class="game-num">№ 01</div>
          <div class="game-art">
            <div class="game-art-corner">
              <span>ANDROID</span>
              <span>★ 4.3</span>
            </div>
            <img src="/images/icon-Arkanoid-classic.png" alt="Arkanoid Classic" loading="lazy" />
          </div>
          <div class="game-body">
            <div class="game-meta">
              <span><b data-i18n="es">Género:</b><b data-i18n="en">Genre:</b> Classic Arcade · Breakout</span>
              <span><span class="dot-android"></span> Android</span>
              <span data-i18n="es"><b>Desde</b> 2014</span>
              <span data-i18n="en"><b>Since</b> 2014</span>
            </div>
            <h3 class="game-title">Arkanoid Classic</h3>

            <dl class="game-stats">
              <div>
                <dt data-i18n="es">Valoración</dt>
                <dt data-i18n="en">Rating</dt>
                <dd>★ 4,3 / 5</dd>
              </div>
              <div>
                <dt data-i18n="es">Descargas</dt>
                <dt data-i18n="en">Downloads</dt>
                <dd>500K+</dd>
              </div>
              <div>
                <dt data-i18n="es">Reseñas</dt>
                <dt data-i18n="en">Reviews</dt>
                <dd>2,38K</dd>
              </div>
            </dl>

            <p class="game-desc" data-i18n="es">
              El clásico arcade de romper ladrillos reinventado para móvil. Controla la plataforma,
              destruye todos los bloques y recoge potenciadores que cambian el ritmo de cada partida.
              Más de 500.000 descargas y una valoración de 4,3 estrellas avalan más de una década
              de diversión arcade pura.
            </p>
            <p class="game-desc" data-i18n="en">
              The classic brick-breaking arcade game reimagined for mobile. Control the paddle,
              destroy every block, and collect power-ups that change the pace of each game.
              Over 500,000 downloads and a 4.3-star rating back up more than a decade
              of pure arcade fun.
            </p>

            <div class="game-tags">
              <span class="pill accent" data-i18n="es">Gratis</span>
              <span class="pill accent" data-i18n="en">Free to play</span>
              <span class="pill" data-i18n="es">Arcade clásico</span>
              <span class="pill" data-i18n="en">Classic arcade</span>
              <span class="pill" data-i18n="es">Sin muros de pago</span>
              <span class="pill" data-i18n="en">No paywalls</span>
              <span class="pill">Breakout</span>
            </div>

            <div class="game-cta">
              <a
                href="https://play.google.com/store/apps/details?id=com.devApplications.Arkanoidclasicfree"
                target="_blank"
                rel="noreferrer"
                class="btn"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.523 0H6.477L0 12l6.477 12h11.046L24 12 17.523 0z" /></svg>
                <span data-i18n="es">Jugar en Google Play</span>
                <span data-i18n="en">Play on Google Play</span>
              </a>
            </div>
          </div>
        </article>

        <!-- Infinite Dark -->
        <article class="game reveal">
          <div class="game-num">№ 02</div>
          <div class="game-art contain">
            <div class="game-art-corner">
              <span>ANDROID</span>
              <span data-i18n="es">NUEVO</span>
              <span data-i18n="en">NEW</span>
            </div>
            <img src="/images/principal-logo-infinite-dark.png" alt="Infinite Dark" loading="lazy" />
          </div>
          <div class="game-body">
            <div class="game-meta">
              <span><b data-i18n="es">Género:</b><b data-i18n="en">Genre:</b> Space Survivor Roguelite</span>
              <span><span class="dot-android"></span> Android</span>
              <span><span class="dot-ios"></span>
                <span data-i18n="es">iOS · Próximamente</span>
                <span data-i18n="en">iOS · Coming Soon</span>
              </span>
            </div>
            <h3 class="game-title">Infinite Dark</h3>

            <dl class="game-stats">
              <div>
                <dt data-i18n="es">Formato</dt>
                <dt data-i18n="en">Format</dt>
                <dd>Roguelite</dd>
              </div>
              <div>
                <dt data-i18n="es">Partida</dt>
                <dt data-i18n="en">Session</dt>
                <dd>5–20′</dd>
              </div>
              <div>
                <dt data-i18n="es">Precio</dt>
                <dt data-i18n="en">Price</dt>
                <dd data-i18n="es">Gratis</dd>
                <dd data-i18n="en">Free</dd>
              </div>
            </dl>

            <p class="game-desc" data-i18n="es">
              Sobrevive a oleadas de enemigos cada vez más agresivas, descubre sinergias entre
              armas que transforman por completo tu estilo de juego y mejora tus estadísticas
              run a run. Un sistema roguelite honesto que siempre te invita a "una partida más".
            </p>
            <p class="game-desc" data-i18n="en">
              Survive increasingly aggressive enemy waves, discover weapon synergies that
              completely transform your playstyle and upgrade your stats run after run.
              An honest roguelite system that always invites you to "one more run".
            </p>

            <div class="game-tags">
              <span class="pill accent" data-i18n="es">Sin muros de pago</span>
              <span class="pill accent" data-i18n="en">No paywalls</span>
              <span class="pill" data-i18n="es">Sin energía</span>
              <span class="pill" data-i18n="en">No energy</span>
              <span class="pill" data-i18n="es">Gratis</span>
              <span class="pill" data-i18n="en">Free to play</span>
              <span class="pill">Roguelite</span>
            </div>

            <div class="game-cta">
              <a
                href="https://play.google.com/store/apps/details?id=com.devapplications.infiniteDark"
                target="_blank"
                rel="noreferrer"
                class="btn"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.523 0H6.477L0 12l6.477 12h11.046L24 12 17.523 0z" /></svg>
                <span data-i18n="es">Jugar en Google Play</span>
                <span data-i18n="en">Play on Google Play</span>
              </a>
            </div>
          </div>
        </article>

        <!-- Upcoming -->
        <article class="game-upcoming reveal">
          <div class="game-num">№ 03</div>
          <div class="game-upcoming-art">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <div class="game-body">
            <div class="stamp">
              <span data-i18n="es">En prototipo</span>
              <span data-i18n="en">In prototype</span>
            </div>
            <h3 class="game-title serif-italic" data-i18n="es">Próximo proyecto.</h3>
            <h3 class="game-title serif-italic" data-i18n="en">Next project.</h3>
            <p class="game-desc" data-i18n="es">
              Estamos prototipando nuevas ideas arcade. Desde shooters más tácticos hasta
              experiencias puramente arcade. Cada nuevo título tendrá su propia página.
            </p>
            <p class="game-desc" data-i18n="en">
              We're prototyping new arcade ideas — from more tactical shooters to pure arcade
              experiments. Every new title will get its own dedicated page.
            </p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── STUDIO ── -->
  <section id="studio" class="band">
    <div class="container">
      <div class="band-head reveal">
        <div class="band-meta">
          <span>§ <strong>03</strong> / <span data-i18n="es">El estudio</span><span data-i18n="en">The studio</span></span>
          <span data-i18n="es">Un desarrollador, una visión</span>
          <span data-i18n="en">One developer, one vision</span>
        </div>
        <h2 class="band-title">
          <span data-i18n="es">Un desarrollador.<br /><em>Una visión clara.</em></span>
          <span data-i18n="en">One developer.<br /><em>One clear vision.</em></span>
        </h2>
      </div>

      <div class="studio-grid">
        <div class="studio-story reveal">
          <p data-i18n="es">
            DevApplications es el estudio personal de <strong>Antonio Ramos</strong>, desarrollador
            indie basado en Barcelona. Cada juego nace con un único objetivo: que sea imposible
            dejar de jugar.
          </p>
          <p data-i18n="en">
            DevApplications is the personal studio of <strong>Antonio Ramos</strong>, an indie
            developer based in Barcelona. Every game is born with a single goal: make it
            impossible to stop playing.
          </p>
          <p data-i18n="es">
            Me apasionan las interfaces limpias, la estética retro‑futurista y la sensación de
            arcade de los recreativos. Esa mezcla inspira tanto el arte visual como el diseño
            de sistemas de cada juego.
          </p>
          <p data-i18n="en">
            I'm passionate about clean interfaces, retro‑futuristic aesthetics, and the arcade
            feeling of old‑school cabinets. That mix inspires both the visuals and systems
            design of every game.
          </p>

          <div class="studio-stats">
            <div>
              <div class="stat-val">02</div>
              <span class="stat-lab" data-i18n="es">Juegos publicados</span>
              <span class="stat-lab" data-i18n="en">Published games</span>
            </div>
            <div>
              <div class="stat-val ital">Solo</div>
              <span class="stat-lab" data-i18n="es">Desarrollador</span>
              <span class="stat-lab" data-i18n="en">Developer</span>
            </div>
            <div>
              <div class="stat-val">BCN</div>
              <span class="stat-lab" data-i18n="es">Barcelona, España</span>
              <span class="stat-lab" data-i18n="en">Barcelona, Spain</span>
            </div>
          </div>
        </div>

        <div class="pillars reveal" style="--d:120ms">
          <div class="pillar">
            <span class="pillar-n">01</span>
            <h4 data-i18n="es"><em>Gameplay</em> primero</h4>
            <h4 data-i18n="en"><em>Gameplay</em> first</h4>
            <p data-i18n="es">El diseño parte siempre de que la mecánica principal sea satisfactoria y adictiva por sí misma.</p>
            <p data-i18n="en">Design always starts from making the core mechanic satisfying and addictive on its own.</p>
          </div>
          <div class="pillar">
            <span class="pillar-n">02</span>
            <h4 data-i18n="es">Monetización <em>ética</em></h4>
            <h4 data-i18n="en">Ethical <em>monetization</em></h4>
            <p data-i18n="es">Sin dark patterns ni pay‑to‑win. El dinero nunca te da ventaja en el juego.</p>
            <p data-i18n="en">No dark patterns or pay‑to‑win. Money never gives you an in‑game advantage.</p>
          </div>
          <div class="pillar">
            <span class="pillar-n">03</span>
            <h4 data-i18n="es">Respeto al <em>jugador</em></h4>
            <h4 data-i18n="en">Player <em>respect</em></h4>
            <p data-i18n="es">Cada run dura lo que tú decides. El juego respeta tu tiempo, no lo secuestra.</p>
            <p data-i18n="en">Each run lasts as long as you decide. The game respects your time — it doesn't hold it hostage.</p>
          </div>
          <div class="pillar">
            <span class="pillar-n">04</span>
            <h4 data-i18n="es"><em>Nativo</em> y rápido</h4>
            <h4 data-i18n="en"><em>Native</em> and fast</h4>
            <p data-i18n="es">Desarrollo nativo Android para máximo rendimiento y controles perfectamente calibrados.</p>
            <p data-i18n="en">Native Android development for maximum performance and perfectly calibrated controls.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ── -->
  <section id="contact" class="contact">
    <div class="container">
      <div class="contact-grid reveal">
        <div>
          <span class="eyebrow">
            <span data-i18n="es">§ 04 / Contacto</span>
            <span data-i18n="en">§ 04 / Contact</span>
          </span>
          <h2>
            <span data-i18n="es">Hablemos <em>de juegos.</em></span>
            <span data-i18n="en">Let's <em>talk games.</em></span>
          </h2>
          <p data-i18n="es">
            ¿Feedback sobre Infinite Dark, una idea de colaboración o simplemente quieres hablar
            de juegos? Escríbeme — siempre es un placer.
          </p>
          <p data-i18n="en">
            Feedback on Infinite Dark, a collaboration idea, or just want to talk games?
            Drop me a line — always happy to chat.
          </p>
        </div>

        <div class="contact-card">
          <div class="contact-card-head">
            <span>∘ OPEN FOR MAIL</span>
            <span>BCN</span>
          </div>
          <span class="eyebrow" style="margin-top:1rem; display:inline-flex;">
            <span data-i18n="es">Escríbeme a</span>
            <span data-i18n="en">Write me at</span>
          </span>
          <a href="mailto:devapplicationsgames@gmail.com" class="contact-email">
            devapplicationsgames@gmail.com
          </a>
          <div class="contact-actions">
            <a href="mailto:devapplicationsgames@gmail.com" class="btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
              <span data-i18n="es">Enviar email</span>
              <span data-i18n="en">Send email</span>
            </a>
            <a
              href="https://play.google.com/store/apps/developer?id=DevApplications"
              target="_blank"
              rel="noreferrer"
              class="btn ghost"
            >
              Google Play
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    padding: clamp(2.5rem, 6vw, 5.5rem) 0 clamp(3rem, 6vw, 6rem);
    position: relative;
  }
  .hero-meta {
    display: flex; align-items: center; gap: .9rem 1.5rem;
    padding-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .hero-meta .eyebrow-num { flex-shrink: 1; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .hero-grid { grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr); }
  }

  .hero-title {
    font-family: var(--f-display);
    font-size: clamp(2.6rem, 10.5vw, 9rem);
    line-height: 0.9;
    font-weight: 400;
    letter-spacing: -0.045em;
    margin: 0.2em 0 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .hero-title .line { display: block; }
  .hero-title .ital { font-style: italic; font-weight: 400; color: var(--accent); }
  .hero-title .u {
    display: inline-block;
    position: relative;
  }
  .hero-title .u::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: .08em;
    height: 0.08em;
    background: var(--accent);
  }

  .hero-sub {
    margin-top: 1.8rem;
    max-width: 32rem;
    font-size: clamp(1rem, 1.2vw + .5rem, 1.2rem);
    color: var(--fg-2);
    line-height: 1.55;
  }
  .hero-sub strong { color: var(--fg); font-weight: 500; }

  .hero-actions {
    display: flex; flex-wrap: wrap; gap: .7rem;
    margin-top: 2rem;
  }

  .hero-card {
    border: 1px solid var(--fg);
    background: var(--bg-2);
    padding: 1rem;
    position: relative;
    overflow: hidden;
  }
  .hero-card::before {
    content: '';
    position: absolute; inset: 4px;
    border: 1px solid var(--line);
    pointer-events: none;
  }
  .hero-card-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 4px 8px 10px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 10px;
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--fg-3);
    position: relative;
    z-index: 1;
  }
  .hero-card-body {
    position: relative;
    aspect-ratio: 1/1;
    background: var(--bg-3);
    display: grid; place-items: center;
    overflow: hidden;
    border: 1px solid var(--line);
  }
  @media (min-width: 900px) {
    .hero-card-body { aspect-ratio: 4/5; }
  }
  .hero-card-body::before {
    content: '';
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(0deg, color-mix(in oklab, var(--fg) 5%, transparent) 0 1px, transparent 1px 3px);
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  :global([data-theme='dark']) .hero-card-body::before { mix-blend-mode: overlay; opacity: .5; }
  .hero-card-body img {
    width: 72%; height: auto;
    filter: drop-shadow(0 8px 30px rgba(0,0,0,.15));
    position: relative;
    z-index: 1;
  }
  :global([data-theme='dark']) .hero-card-body img { filter: drop-shadow(0 12px 40px rgba(0,0,0,.6)); }

  .hero-card-foot {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    padding-top: 10px;
    margin-top: 10px;
    border-top: 1px solid var(--line);
  }
  .hero-card-foot > div { padding: 4px 8px; border-right: 1px solid var(--line); }
  .hero-card-foot > div:last-child { border-right: 0; }
  .hero-card-foot dt {
    font-family: var(--f-mono);
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .hero-card-foot dd {
    font-family: var(--f-display);
    font-size: clamp(15px, 3.5vw, 18px);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg);
  }

  .scroll-cue {
    margin-top: 3rem;
    display: flex; justify-content: space-between; align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .scroll-arrow {
    width: 18px; height: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--accent);
    animation: arrow 2.2s var(--ease) infinite;
  }
  @keyframes arrow {
    0%, 100% { transform: translateY(0); opacity: .7; }
    50% { transform: translateY(4px); opacity: 1; }
  }
